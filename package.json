{
  "name": "clickup-cli",
  "version": "0.1.0",
  "description": "Comprehensive CLI covering the entire ClickUp API v2 surface",
  "type": "module",
  "bin": {
    "clickup": "./dist/clickup.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills"
  ],
  "scripts": {
    "dev": "tsx bin/clickup.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clickup",
    "cli",
    "project-management",
    "tasks",
    "api"
  ],
  "author": "Henry Reith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/henryreith/clickup-cli.git"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ora": "^8.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
