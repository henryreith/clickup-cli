{
  "name": "clickup-agent-cli",
  "version": "0.2.1",
  "description": "CLI covering the entire ClickUp API v2 surface",
  "type": "module",
  "bin": {
    "clickup": "./dist/bin/clickup.js"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/clickup.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clickup",
    "cli",
    "agent",
    "project-management",
    "tasks",
    "mcp"
  ],
  "author": "Henry Reith",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "conf": "^13.0.0",
    "ora": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
