{
  "name": "clickup-cli",
  "version": "0.1.0",
  "description": "CLI covering the entire ClickUp API v2 surface",
  "type": "module",
  "bin": {
    "clickup": "./dist/bin/clickup.js"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/clickup.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clickup",
    "cli",
    "project-management",
    "tasks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/henryreith/clickup-cli.git"
  },
  "author": "Henry Reith",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "ora": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
